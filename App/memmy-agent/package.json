{
  "name": "memmy-agent",
  "version": "1.0.2",
  "description": "TypeScript refactor of memmy's agent runtime.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "memmy": "./dist/main.js"
  },
  "scripts": {
    "version:sync": "npm --prefix ../.. run version:sync",
    "prebuild": "npm run version:sync",
    "pretypecheck": "npm run version:sync",
    "pretest": "npm run version:sync",
    "pretest:tui-cursor": "npm run version:sync",
    "build": "tsc -p tsconfig.build.json && find src/templates src/skills -type f ! -name '*.ts' -exec sh -c 'for file do target=\"dist/${file#src/}\"; mkdir -p \"$(dirname \"$target\")\"; cp -p \"$file\" \"$target\"; done' sh {} +",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:tui-cursor": "vitest run tests/entrypoints/cli/tui-cursor.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@aws-sdk/client-bedrock-runtime": "^3.1061.0",
    "@aws-sdk/credential-providers": "^3.1061.0",
    "@clack/core": "^1.4.2",
    "@clack/prompts": "^1.6.0",
    "@larksuiteoapi/node-sdk": "^1.66.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.16.0",
    "@tencent-connect/openclaw-qqbot": "^1.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "@wecom/aibot-node-sdk": "^1.0.7",
    "better-sqlite3": "^12.11.1",
    "botbuilder": "^4.23.3",
    "commander": "^14.0.2",
    "cron-parser": "^5.5.0",
    "dingtalk-stream": "^2.1.6-beta.1",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "eventsource": "^4.1.0",
    "exceljs": "^4.4.0",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.8.0",
    "grammy": "^1.43.0",
    "iconv-lite": "^0.7.2",
    "imapflow": "^1.3.5",
    "ink": "^6.8.0",
    "isomorphic-git": "^1.38.4",
    "jsonrepair": "^3.14.0",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "mammoth": "^1.12.0",
    "matrix-js-sdk": "^41.7.0-rc.3",
    "mime-types": "^3.0.2",
    "minimatch": "^10.1.1",
    "nodemailer": "^8.0.10",
    "nunjucks": "^3.2.4",
    "openai": "^6.42.0",
    "pdfjs-dist": "^6.0.227",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "slackify-markdown": "^5.0.0",
    "socket.io-client": "^4.8.3",
    "string-width": "^4.2.3",
    "tiktoken": "^1.0.22",
    "turndown": "^7.2.4",
    "undici": "^6.27.0",
    "which": "^5.0.0",
    "ws": "^8.21.0",
    "yaml": "^2.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/nunjucks": "^3.2.6",
    "@types/proper-lockfile": "^4.1.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/turndown": "^5.0.6",
    "@types/which": "^3.0.4",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=22"
  }
}
